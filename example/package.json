{
  "name": "command-frame-example-web-app",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky"
  },
  "dependencies": {
    "@final-commerce/command-frame": "file:..",
    "@final-commerce/common": "file:../../common",
    "@final-commerce/pos-brain": "file:../../pos-brain",
    "@final-commerce/port-louis": "file:../../port-louis",
    "@reduxjs/toolkit": "2.0.1",
    "@sentry/react": "^10.22.0",
    "jwt-decode": "^4.0.0",
    "lokijs": "^1.5.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "9.1.0",
    "react-router-dom": "^7.12.0",
    "socket.io-client": "^4.8.1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^7.0.6",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "prettier": "@final-commerce/common/prettier",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
